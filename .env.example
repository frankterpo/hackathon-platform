# Supabase (Project Settings → API). Replace ref and keys with your project’s values.
# Next.js loads `.env`, `.env.local`, etc.; use `.env.local` for secrets and restart `npm run dev` after edits.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional CLI-style alias (server-only reads either this or NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Optional: same value as anon key; Dashboard “Connect” snippets often use this name only.
# SUPABASE_ANON_KEY=your_anon_key
# Server-only. Required for reading without broad RLS policies and for /admin hackathon inserts.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: overrides default ref used for dashboard links in the UI
NEXT_PUBLIC_SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Optional: when set, Vercel project links resolve to https://vercel.com/<team>/<slug>
NEXT_PUBLIC_VERCEL_TEAM=

# Shared secret for the “Create hackathon” form on /admin/master-panel (server compares to this value)
ADMIN_SECRET=change-me-local-only

# Optional · development only — placeholder Kanban rows when DB is empty or query fails
# NEXT_PUBLIC_USE_MOCK_HACKATHONS=1

# Optional Luma ingestion fallback. Public event pages work for normal metadata; only set one
# of these locally if Luma changes a page to require your browser session. Never commit values.
# LUMA_AUTH_TOKEN=
# LUMA_COOKIE=

# Vercel CLI pulls (scripts/sync-vercel-envs.sh) — see also .env.vercel.* generated files
# VERCEL_ENV=production
