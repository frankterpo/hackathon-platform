# Supabase (Project Settings → API). Replace ref and keys with your project’s values.
# Next.js loads `.env`, `.env.local`, etc.; use `.env.local` for secrets and restart `npm run dev` after edits.
# YOUR_PROJECT_REF = same id as in the dashboard URL …/project/YOUR_PROJECT_REF and as the subdomain here:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional CLI-style alias (server-only reads either this or NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Optional: same value as anon key; Dashboard “Connect” snippets often use this name only.
# SUPABASE_ANON_KEY=your_anon_key
# Server-only. Required for reading without broad RLS policies and for /admin hackathon inserts.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: overrides default ref used for dashboard links in the UI
NEXT_PUBLIC_SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Optional: when set, Vercel project links resolve to https://vercel.com/<team>/<slug>
NEXT_PUBLIC_VERCEL_TEAM=

# Shared secret for `/app/master` login and the inline “Create hackathon” ADMIN_SECRET field (server compares to this value)
ADMIN_SECRET=change-me-local-only

# Optional: /app/master overview hides hacks without Firebase project id as well as without Luma id
# MASTER_OVERVIEW_REQUIRE_FIREBASE=1

# Optional · development only — placeholder Kanban rows when DB is empty or query fails
# NEXT_PUBLIC_USE_MOCK_HACKATHONS=1

# Optional Luma ingestion fallback. Public event pages work for normal metadata; only set one
# of these locally if Luma changes a page to require your browser session. Never commit values.
# LUMA_AUTH_TOKEN=
# LUMA_COOKIE=

# Optional: npm test HTTP smoke (app must be running: npm run start / dev)
# SMOKE_BASE_URL=http://127.0.0.1:3000
# SMOKE_HACKATHON_ID=00000000-0000-4000-8000-000000000001

# Vercel CLI pulls (scripts/sync-vercel-envs.sh) — see also .env.vercel.* generated files
# VERCEL_ENV=production

# --- V1 portals (credits / submit / judge) -----------------------------------
# Firebase admin — ONE project per hack. For each hack, set:
#   FIREBASE_SA__<firebase_config_ref with hyphens replaced by underscores>
#   = the entire service-account JSON (single line)
# Example for thrads:
#   FIREBASE_SA__cursor_thrads_london_2026={"type":"service_account",...}
# FIREBASE_CREDITS_COLLECTION=credit_links

# Luma sync via browser-use cloud (cron + admin-trigger at /api/luma/sync)
# 1) Create an API key:                 https://cloud.browser-use.com/settings?tab=api-keys&new=1
# 2) Create a profile named "luma":     https://cloud.browser-use.com/settings?tab=profiles
#    Then open a session against it and log into lu.ma manually (one time).
#    Same logged-in profile is reused across hacks (evt- ids differ per hackathon row).
# 3) Set the API key here. By default the app finds the profile named "luma".
# Optional: pin the profile UUID from the dashboard (skips list/create by name).
# BROWSER_USE_LUMA_PROFILE_ID=00000000-0000-4000-8000-000000000001
# BROWSER_USE_API_KEY=bu_...
# Optional: explicit Luma evt-id → hackathon UUID map. If unset, the route
# uses each hackathon's `luma_event_id` column.
# LUMA_HACK_MAP={"evt-abc":"<hackathon-uuid>"}
# Required only for cron / curl access. Admin cookie also works from /app/master.
# CRON_SECRET=

# Themed-domain → hack page rewriter (Next.js middleware.ts)
# HACK_PAGE_DOMAIN_MAP={"cursor-thrads-london-2026.vercel.app":"99c06fd0-c64a-4555-a38f-497eac67a50f"}
