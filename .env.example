# Supabase (dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://wkzczywhgxzttyfzhgck.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side reads with RLS bypass (keep private; never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
# Optional: overrides default ref used for Supabase dashboard links in the UI
NEXT_PUBLIC_SUPABASE_PROJECT_REF=wkzczywhgxzttyfzhgck

# Optional: when set, Vercel project links resolve to https://vercel.com/<team>/<slug>
NEXT_PUBLIC_VERCEL_TEAM=

# Vercel CLI pulls (scripts/sync-vercel-envs.sh) — also see .env.vercel.* generated files
# VERCEL_ENV=production
